# ============================================
# TELEGRAM CONFIGURATION
# ============================================
TELEGRAM_BOT_TOKEN=tu_token_aqui
# Allowed chat IDs for the bot (comma-separated)
ALLOWED_CHAT_IDS=123456789,987654321

# Contact name for welcome messages
TELEGRAM_CONTACT_NAME=Marelia

# ============================================
# GEMINI (Google AI) CONFIGURATION
# ============================================
GEMINI_API_KEY=tu_api_key_aqui

# ============================================
# NOTION CONFIGURATION
# ============================================
NOTION_API_KEY=tu_notion_token_aqui
# Database ID where books are stored
NOTION_DATABASE_ID=tu_database_id
# Template ID used to create new entries
NOTION_TEMPLATE_ID=tu_template_id

# ============================================
# GENERAL CONFIGURATION
# ============================================
# Dry run: if true, the bot won't make real changes in Notion
DRY_RUN=false
